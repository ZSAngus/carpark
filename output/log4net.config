<!--  澳門通Reader日志 -->
  <appender name="MPass03360101Appender" type="log4net.Appender.RollingFileAppender" >
    <file value="Logs\\MPass\\Command\\03360101\\" />
    <appendToFile value="true" />
    <datePattern value="yyyyMMdd'_03360101.log'" />
    <maxSizeRollBackups value="10" />
    <rollingStyle value="Date" />
    <maximumFileSize value="10MB" />
    <staticLogFileName value="false" />
    <layout type="log4net.Layout.PatternLayout">
      <param name="ConversionPattern" value="%d{yyyy-MM-dd HH:mm:ss} %m %n" />
    </layout>
    <!--<filter type="log4net.Filter.LevelRangeFilter">
      <param name="LevelMin" value="FATAL" />
      <param name="LevelMax" value="FATAL" />
    </filter>-->
  </appender>


  <logger name="MPass03360101" additivity="false">
    <level value="ALL" />
    <appender-ref ref="MPass03360101Appender" />
  </logger>


  <!--澳門通Manager相關-->
  <logger name="MPassLogger" additivity="false">
    <level value="ALL" />
    <appender-ref ref="MPPassAppenderInfo" />
    <appender-ref ref="MPPassAppenderDebug" />
    <appender-ref ref="MPPassAppenderError" />
    <appender-ref ref="MPPassAppenderWarn" />
    <appender-ref ref="MPPassAppenderFatal" />
  </logger>

  <logger name="MPPOSLogger" additivity="false">
    <level value="ALL" />
    <appender-ref ref="POSAppenderInfo" />
    <appender-ref ref="POSAppenderDebug" />
    <appender-ref ref="POSAppenderError" />
    <appender-ref ref="POSAppenderWarn" />
    <appender-ref ref="POSAppenderFatal" />
  </logger>

  <root>
    <level value="ALL" />
    <appender-ref ref="INFO" />
    <appender-ref ref="DEBUG" />
    <appender-ref ref="ERROR" />
    <appender-ref ref="WARN" />
    <appender-ref ref="FATAL" />
  </root>

</log4net>